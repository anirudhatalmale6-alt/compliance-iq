generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
  schemas   = ["compliance"]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companies CompanyUser[]
  @@schema("compliance")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  cin         String?  @unique
  gstin       String?
  pan         String?
  dateOfIncorporation DateTime?
  registeredOffice    String?
  companyType         String?
  companyStatus       String?
  authorizedCapital   String?
  paidUpCapital       String?
  state               String?
  city                String?
  email               String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       CompanyUser[]
  mcaFilings  MCAFiling[]
  gstReturns  GSTReturn[]
  complianceChecks ComplianceCheck[]
  directors   Director[]
  charges     Charge[]
  complianceOverrides ComplianceOverride[]
  @@schema("compliance")
}

model CompanyUser {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  role      String  @default("VIEWER")
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])
  @@unique([userId, companyId])
  @@schema("compliance")
}

model Director {
  id          String   @id @default(cuid())
  companyId   String
  din         String?
  name        String
  designation String?
  dateOfAppointment DateTime?
  cessationDate     DateTime?
  kycStatus   String?
  company     Company  @relation(fields: [companyId], references: [id])
  @@schema("compliance")
}

model MCAFiling {
  id          String   @id @default(cuid())
  companyId   String
  formType    String
  formName    String
  filingDate  DateTime?
  dueDate     DateTime?
  status      String
  financialYear String?
  details     String?
  penalty     String?
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  @@schema("compliance")
}

model GSTReturn {
  id          String   @id @default(cuid())
  companyId   String
  returnType  String
  period      String
  dueDate     DateTime?
  filingDate  DateTime?
  status      String
  taxPaid     Float?
  lateFee     Float?
  details     String?
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  @@schema("compliance")
}

model ComplianceCheck {
  id          String   @id @default(cuid())
  companyId   String
  category    String
  checkName   String
  description String
  status      String
  severity    String
  action      String?
  deadline    DateTime?
  penalty     String?
  reference   String?
  company     Company  @relation(fields: [companyId], references: [id])
  checkedAt   DateTime @default(now())
  @@schema("compliance")
}

model Charge {
  id          String   @id @default(cuid())
  companyId   String
  chargeId    String?
  chargeHolder String?
  dateOfCreation DateTime?
  dateOfModification DateTime?
  status      String?
  amount      String?
  company     Company  @relation(fields: [companyId], references: [id])
  @@schema("compliance")
}

model ComplianceOverride {
  id          String   @id @default(cuid())
  companyId   String
  checkName   String
  status      String
  notes       String?
  verifiedAt  DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
  @@unique([companyId, checkName])
  @@schema("compliance")
}
